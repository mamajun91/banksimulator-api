<!-- TABLE : piece_identite                     -->
<!-- ══════════════════════════════════════════ -->

<table name="piece_identite" layers="0" collapse-mode="2" max-obj-count="6" z-value="0">
	<schema name="public"/>
	<position x="50" y="500"/>
	<column name="id" not-null="true" default-value="gen_random_uuid()">
