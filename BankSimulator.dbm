<dbmodel pgmodeler-ver="1.1.0" last-position="0,0" last-zoom="1" max-obj-count="20"
	 default-schema="public" default-owner="postgres"
	 layers="Default layer"
	 active-layers="0"
	 layer-name-colors="#000000"
	 layer-rect-colors="#b4b4b4"
	 show-layer-names="false" show-layer-rects="false">

<database name="banksimulator" encoding="UTF8" lc-collate="fr_FR.UTF-8" lc-ctype="fr_FR.UTF-8" is-template="false" allow-conns="true">
</database>

<schema name="public" layers="0" fill-color="#e2eef6" name-color="#000000" sql-disabled="true">
</schema>

<!-- ══════════════════════════════════════════ -->
<!-- ENUMS                                      -->
<!-- ══════════════════════════════════════════ -->

<usertype name="role_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="ADMIN"/>
	<enumeration label="CLIENT"/>
	<enumeration label="CONSEILLER"/>
	<enumeration label="AUDITEUR"/>
</usertype>

<usertype name="statut_utilisateur_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="ACTIF"/>
	<enumeration label="BLOQUE"/>
	<enumeration label="SUSPENDU"/>
</usertype>

<usertype name="type_compte_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="COURANT"/>
	<enumeration label="EPARGNE"/>
</usertype>

<usertype name="statut_compte_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="ACTIF"/>
	<enumeration label="BLOQUE"/>
	<enumeration label="CLOTURE"/>
</usertype>

<usertype name="type_transaction_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="VIREMENT"/>
	<enumeration label="DEPOT"/>
	<enumeration label="RETRAIT"/>
</usertype>

<usertype name="statut_transaction_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="PENDING"/>
	<enumeration label="COMPLETED"/>
	<enumeration label="FAILED"/>
	<enumeration label="CANCELLED"/>
</usertype>

<usertype name="type_piece_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="CNI"/>
	<enumeration label="PASSEPORT"/>
	<enumeration label="TITRE_SEJOUR"/>
</usertype>

<usertype name="entite_cible_enum" configuration="enumeration">
	<schema name="public"/>
	<enumeration label="COMPTE"/>
	<enumeration label="TRANSACTION"/>
	<enumeration label="UTILISATEUR"/>
	<enumeration label="PIECE_IDENTITE"/>
</usertype>

<!-- ══════════════════════════════════════════ -->
<!-- TABLE : action                             -->
<!-- ══════════════════════════════════════════ -->

<table name="action" layers="0" collapse-mode="2" max-obj-count="3" z-value="0">
	<schema name="public"/>
	<position x="900" y="50"/>
	<column name="id" not-null="true" default-value="gen_random_uuid()">
		<type name="uuid" length="0"/>
	</column>
	<column name="code" not-null="true">
		<type name="varchar" length="100"/>
	</column>
	<column name="libelle" not-null="true">
		<type name="varchar" length="255"/>
	</column>
	<constraint name="pk_action" type="pk-constr" table="public.action">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
	<constraint name="uq_action_code" type="uq-constr" table="public.action">
		<columns names="code" ref-type="src-columns"/>
	</constraint>
</table>

<!-- ══════════════════════════════════════════ -->
<!-- TABLE : utilisateur                        -->
<!-- ══════════════════════════════════════════ -->

<table name="utilisateur" layers="0" collapse-mode="2" max-obj-count="17" z-value="0">
	<schema name="public"/>
	<position x="50" y="50"/>
	<column name="id" not-null="true" default-value="gen_random_uuid()">
		<type name="uuid" length="0"/>
	</column>
	<column name="nom" not-null="true">
		<type name="varchar" length="100"/>
	</column>
	<column name="prenom" not-null="true">
		<type name="varchar" length="100"/>
	</column>
	<column name="email" not-null="true">
		<type name="varchar" length="255"/>
	</column>
	<column name="telephone">
		<type name="varchar" length="20"/>
	</column>
	<column name="date_naissance" not-null="true">
		<type name="date" length="0"/>
	</column>
	<column name="adresse_rue" not-null="true">
		<type name="varchar" length="255"/>
	</column>
	<column name="adresse_ville" not-null="true">
		<type name="varchar" length="100"/>
	</column>
	<column name="code_postal" not-null="true">
		<type name="varchar" length="10"/>
	</column>
	<column name="pays" not-null="true" default-value="'FR'">
		<type name="char" length="2"/>
	</column>
	<column name="mot_de_passe_hash" not-null="true">
		<type name="varchar" length="255"/>
	</column>
	<column name="role" not-null="true">
		<type name="role_enum" length="0"/>
	</column>
	<column name="statut" not-null="true" default-value="'ACTIF'">
		<type name="statut_utilisateur_enum" length="0"/>
	</column>
	<column name="nb_echecs_auth" not-null="true" default-value="0">
		<type name="integer" length="0"/>
	</column>
	<column name="date_creation" not-null="true" default-value="now()">
		<type name="timestamp" length="0"/>
	</column>
	<column name="date_modification" not-null="true" default-value="now()">
		<type name="timestamp" length="0"/>
	</column>
	<column name="version" not-null="true" default-value="0">
		<type name="bigint" length="0"/>
	</column>
	<constraint name="pk_utilisateur" type="pk-constr" table="public.utilisateur">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
	<constraint name="uq_utilisateur_email" type="uq-constr" table="public.utilisateur">
		<columns names="email" ref-type="src-columns"/>
	</constraint>
	<constraint name="ck_utilisateur_age" type="ck-constr" table="public.utilisateur">
		<expression><![CDATA[date_naissance <= current_date - interval '18 years']]></expression>
	</constraint>
	<constraint name="ck_utilisateur_echecs" type="ck-constr" table="public.utilisateur">
		<expression><![CDATA[nb_echecs_auth >= 0 AND nb_echecs_auth <= 3]]></expression>
	</constraint>
</table>

