<relationship name="fk_piece_utilisateur" type="rel1n" layers="0"
	 src-col-pattern="{sc}" pk-pattern="{dt}_pk" uq-pattern="{dt}_uq"
	 src-fk-pattern="{st}_fk"
	 custom-color="#2e7d32"
	 src-table="public.utilisateur"
	 dst-table="public.piece_identite"
	 src-required="true" dst-required="false">
