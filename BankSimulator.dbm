	</column>
	<column name="type_piece" not-null="true">
		<type name="type_piece_enum" length="0"/>
	</column>
	<column name="numero" not-null="true">
		<type name="varchar" length="50"/>
	</column>
	<column name="date_expiration" not-null="true">
		<type name="date" length="0"/>
	</column>
	<column name="date_creation" not-null="true" default-value="now()">
		<type name="timestamp" length="0"/>
	</column>
	<constraint name="pk_piece_identite" type="pk-constr" table="public.piece_identite">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
	<constraint name="uq_piece_numero" type="uq-constr" table="public.piece_identite">
		<columns names="numero" ref-type="src-columns"/>
	</constraint>
</table>

<!-- ══════════════════════════════════════════ -->
<!-- TABLE : compte_bancaire                    -->
<!-- ══════════════════════════════════════════ -->

<table name="compte_bancaire" layers="0" collapse-mode="2" max-obj-count="13" z-value="0">
	<schema name="public"/>
	<position x="450" y="50"/>
	<column name="id" not-null="true" default-value="gen_random_uuid()">
		<type name="uuid" length="0"/>
	</column>
	<column name="titulaire_id" not-null="true">
		<type name="uuid" length="0"/>
	</column>
	<column name="conseiller_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="iban" not-null="true">
		<type name="varchar" length="34"/>
	</column>
	<column name="bic" not-null="true">
		<type name="varchar" length="11"/>
	</column>
	<column name="type_compte" not-null="true">
		<type name="type_compte_enum" length="0"/>
	</column>
	<column name="solde" not-null="true" default-value="0.00">
		<type name="numeric" length="15" precision="2"/>
	</column>
	<column name="devise" not-null="true" default-value="'EUR'">
		<type name="char" length="3"/>
	</column>
	<column name="decouvert_autorise" not-null="true" default-value="0.00">
		<type name="numeric" length="15" precision="2"/>
	</column>
	<column name="taux_interet" default-value="0.0000">
		<type name="numeric" length="5" precision="4"/>
	</column>
	<column name="statut" not-null="true" default-value="'ACTIF'">
		<type name="statut_compte_enum" length="0"/>
	</column>
	<column name="date_ouverture" not-null="true" default-value="current_date">
		<type name="date" length="0"/>
	</column>
	<column name="date_cloture">
		<type name="date" length="0"/>
	</column>
	<column name="date_modification" not-null="true" default-value="now()">
		<type name="timestamp" length="0"/>
	</column>
	<column name="version" not-null="true" default-value="0">
		<type name="bigint" length="0"/>
	</column>
	<constraint name="pk_compte_bancaire" type="pk-constr" table="public.compte_bancaire">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
	<constraint name="uq_compte_iban" type="uq-constr" table="public.compte_bancaire">
		<columns names="iban" ref-type="src-columns"/>
	</constraint>
	<constraint name="ck_compte_solde" type="ck-constr" table="public.compte_bancaire">
		<expression><![CDATA[solde >= -decouvert_autorise]]></expression>
	</constraint>
</table>

<!-- ══════════════════════════════════════════ -->
<!-- TABLE : transaction                        -->
<!-- ══════════════════════════════════════════ -->

<table name="transaction" layers="0" collapse-mode="2" max-obj-count="14" z-value="0">
	<schema name="public"/>
	<position x="450" y="450"/>
	<column name="id" not-null="true" default-value="gen_random_uuid()">
		<type name="uuid" length="0"/>
	</column>
	<column name="reference" not-null="true">
		<type name="varchar" length="35"/>
	</column>
	<column name="type_transaction" not-null="true">
		<type name="type_transaction_enum" length="0"/>
	</column>
	<column name="montant" not-null="true">
		<type name="numeric" length="15" precision="2"/>
	</column>
	<column name="devise" not-null="true" default-value="'EUR'">
		<type name="char" length="3"/>
	</column>
	<column name="libelle">
		<type name="varchar" length="140"/>
	</column>
	<column name="statut" not-null="true" default-value="'PENDING'">
		<type name="statut_transaction_enum" length="0"/>
	</column>
	<column name="compte_debiteur_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="compte_crediteur_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="initiateur_id" not-null="true">
		<type name="uuid" length="0"/>
	</column>
	<column name="iban_externe">
		<type name="varchar" length="34"/>
	</column>
	<column name="date_execution" not-null="true" default-value="now()">
		<type name="timestamp" length="0"/>
	</column>
	<column name="date_valeur">
		<type name="date" length="0"/>
	</column>
	<column name="message_erreur">
		<type name="varchar" length="255"/>
	</column>
	<column name="version" not-null="true" default-value="0">
		<type name="bigint" length="0"/>
	</column>
	<constraint name="pk_transaction" type="pk-constr" table="public.transaction">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
	<constraint name="uq_transaction_reference" type="uq-constr" table="public.transaction">
		<columns names="reference" ref-type="src-columns"/>
	</constraint>
	<constraint name="ck_transaction_montant" type="ck-constr" table="public.transaction">
		<expression><![CDATA[montant >= 0.01]]></expression>
	</constraint>
</table>

<!-- ══════════════════════════════════════════ -->
<!-- TABLE : audit_trail                        -->
<!-- ══════════════════════════════════════════ -->

<table name="audit_trail" layers="0" collapse-mode="2" max-obj-count="11" z-value="0">
	<schema name="public"/>
	<position x="900" y="450"/>
	<column name="id" not-null="true" default-value="gen_random_uuid()">
		<type name="uuid" length="0"/>
	</column>
	<column name="utilisateur_id" not-null="true">
		<type name="uuid" length="0"/>
	</column>
	<column name="action_id" not-null="true">
		<type name="uuid" length="0"/>
	</column>
	<column name="entite_cible" not-null="true">
		<type name="entite_cible_enum" length="0"/>
	</column>
	<column name="entite_id">
		<type name="uuid" length="0"/>
	</column>
	<column name="ancien_etat">
		<type name="jsonb" length="0"/>
	</column>
	<column name="nouvel_etat">
		<type name="jsonb" length="0"/>
	</column>
	<column name="endpoint">
		<type name="varchar" length="200"/>
	</column>
	<column name="adresse_ip">
		<type name="varchar" length="45"/>
	</column>
	<column name="user_agent">
		<type name="varchar" length="500"/>
	</column>
	<column name="timestamp" not-null="true" default-value="now()">
		<type name="timestamp" length="0"/>
	</column>
	<constraint name="pk_audit_trail" type="pk-constr" table="public.audit_trail">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
</table>

